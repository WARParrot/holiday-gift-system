# ─────────────────────────────────────────────────────────────────────────────
# BCMS server configuration.
# Copy to `.env` (in this server/ folder) and fill in as needed:
#     cp .env.example .env       # PowerShell: copy .env.example .env
# The server AUTO-LOADS server/.env at startup (via src/env.ts), resolved
# relative to the server root so it works from any working directory. Real
# OS/shell environment variables take precedence over .env. `.env` is
# git-ignored; this .example file is the tracked, secret-free template.
# Every value here is optional in development. In production, JWT_SECRET is
# REQUIRED (the server refuses to boot with the insecure default).
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
HOST=127.0.0.1
PORT=4000
# REQUIRED in production. Use a long random value, e.g. `openssl rand -hex 32`.
JWT_SECRET=dev-insecure-secret-change-me
# Access-token lifetime in seconds (default 7 days).
JWT_TTL=604800
# SQLite file path, or ':memory:' for ephemeral runs.
DB_FILE=./data/app.db

# --- Scheduler ---
# Days before a birthday to auto-open a crowdfunding pool.
POOL_LEAD_DAYS=14
# Reminder offsets (days before birthday), comma-separated.
REMINDER_OFFSETS=7,3,1
# Scheduler tick interval in ms (default 1h). Lower it for demos. Set 0 to skip.
SCHEDULER_INTERVAL_MS=3600000
# Set to 0 to disable the background scheduler entirely.
ENABLE_SCHEDULER=1

# --- Security / networking ---
# Comma-separated CORS allowlist. Empty = same-origin only (recommended in
# single-process production). Use '*' only for local cross-origin dev.
CORS_ORIGINS=
# Fixed-window rate limiting (per IP).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=10

# Public base URL the browser reaches this server on. Used to build OAuth
# redirect URIs when the per-provider *_REDIRECT_URI is not set explicitly.
# Include the scheme and (if non-standard) port. No trailing slash.
PUBLIC_BASE_URL=http://localhost:4000

# ─────────────────────────────────────────────────────────────────────────────
# External calendar sync (Google Calendar + Yandex Calendar).
#
# Each provider is LIVE only when BOTH its client id and secret are set below.
# With them unset, that provider runs in demo mode (events are recorded
# in-memory, nothing is written to a real calendar) so the app works with zero
# setup. See docs/CALENDAR_OAUTH_SETUP.md for how to obtain these credentials.
# ─────────────────────────────────────────────────────────────────────────────

# --- Google Calendar (OAuth2 + Calendar API v3) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI in your Google OAuth client.
# Defaults to ${PUBLIC_BASE_URL}/api/calendar/oauth/google/callback when unset.
GOOGLE_REDIRECT_URI=
# Which calendar to write into (default: the user's primary calendar).
GOOGLE_CALENDAR_ID=primary
# Overridable endpoints/scope (defaults target real Google; override for tests).
# GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
# GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
# GOOGLE_CALENDAR_API_BASE=https://www.googleapis.com/calendar/v3
# GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
# GOOGLE_SCOPE=https://www.googleapis.com/auth/calendar.events openid email

# --- Yandex Calendar (CalDAV + app password — NOT OAuth) ---
# Yandex Calendar syncs over CalDAV with HTTP Basic auth using a Yandex login +
# an app-specific password; it does NOT accept OAuth. So there is no client
# id/secret. Set the flag below to enable live Yandex sync; each user then
# connects by entering their login + Calendar app password in the app.
YANDEX_CALDAV_ENABLED=1
# Overridable CalDAV endpoint + collection path (defaults target real Yandex).
# {login} is replaced with the login the connecting user supplies.
# YANDEX_CALDAV_BASE=https://caldav.yandex.ru
# YANDEX_CALDAV_PATH_TEMPLATE=/calendars/{login}/events-default/
