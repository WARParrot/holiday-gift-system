# Server configuration (copy to .env for local overrides; sensible defaults are baked in)
PORT=4000
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=7d
DB_PATH=./data/bcms.db
# Number of days before a birthday to auto-create a crowdfunding pool
POOL_LEAD_DAYS=14
# Reminder offsets (days before birthday), comma-separated
REMINDER_OFFSETS=7,3,1
# Scheduler tick interval in milliseconds (default 1h). Lower it for demos.
SCHEDULER_INTERVAL_MS=3600000
